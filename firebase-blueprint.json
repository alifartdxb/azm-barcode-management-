{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Stock inventory item",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "name_ar": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "unit": { "type": "string" },
        "selling_price": { "type": "number" },
        "cost_price": { "type": "number" },
        "vat": { "type": "number" },
        "supplier": { "type": "string" },
        "stock_quantity": { "type": "integer" },
        "description": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["sku", "barcode", "name"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer record for billing and CRM",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "name_ar": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "trn": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" }
      },
      "required": ["name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier record for procurement",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "name_ar": { "type": "string" },
        "contact_person": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "trn": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" }
      },
      "required": ["name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sales invoice with nested items",
      "type": "object",
      "properties": {
        "invoice_number": { "type": "string" },
        "customer_id": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_trn": { "type": "string" },
        "date": { "type": "string" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "vat_amount": { "type": "number" },
        "grand_total": { "type": "number" },
        "payment_status": { "type": "string" },
        "payment_method": { "type": "string" },
        "notes": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["invoice_number", "customer_name", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all inventory products"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of all customers"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Collection of all suppliers"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of all sales invoices"
    }
  }
}
