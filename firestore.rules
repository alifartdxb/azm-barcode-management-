rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if ID is valid format
    function isValidId(id) {
      return id.size() > 0 && id.size() <= 128;
    }

    match /products/{productId} {
      allow read, write: if isValidId(productId);
    }

    match /customers/{customerId} {
      allow read, write: if isValidId(customerId);
    }

    match /suppliers/{supplierId} {
      allow read, write: if isValidId(supplierId);
    }

    match /invoices/{invoiceId} {
      allow read, write: if isValidId(invoiceId);
    }
  }
}
